{
  "name": "qvora",
  "private": true,
  "version": "0.1.1",
  "description": "Qvora — AI-powered performance creative SaaS. Born to Convert.",
  "workspaces": ["src/apps/*", "src/packages/*"],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "validate:phase1-phase2": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/validate-phase1-phase2.ps1",
    "sync:wiki-memory": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/sync-wiki-memory.ps1",
    "sync:wiki-memory:stage": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/stage-wiki-memory-sync.ps1",
    "sync:wiki-memory:all": "npm run sync:wiki-memory && npm run sync:wiki-memory:stage",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "lefthook": "^1.10.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
