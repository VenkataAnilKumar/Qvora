# Normalize text files to LF in the repository
* text=auto eol=lf

# Keep Windows command scripts CRLF when checked out
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Shell scripts should stay LF
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.mp4 binary
*.mov binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
